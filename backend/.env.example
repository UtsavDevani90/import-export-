# ── Google OAuth ────────────────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI:
#    - http://localhost:5000/api/users/auth/google/callback  (local)
#    - https://your-app.onrender.com/api/users/auth/google/callback  (prod)
# 4. Copy Client ID and Secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev callback URL:
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/users/auth/google/callback
# Production callback URL:
GOOGLE_CALLBACK_URL=https://your-app.onrender.com/api/users/auth/google/callback