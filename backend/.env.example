NODE_ENV=production
PORT=10000

# ── Database ──────────────────────────────────────────────────
# Get your connection string from https://console.neon.tech/
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST/DATABASE?sslmode=require

# ── JWT ───────────────────────────────────────────────────────
# IMPORTANT: Generate strong secrets before deploying to production.
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRE=15m

# Refresh token secret (different from JWT_SECRET)
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_SECRET_64_CHARS
JWT_REFRESH_EXPIRE=7d

# ── Frontend URL ──────────────────────────────────────────────
CLIENT_URL=https://your-frontend.vercel.app

# ── Admin Seeding ─────────────────────────────────────────────
# Set these to auto-create the first superadmin on server startup.
# Once admin exists, these can be removed.
ADMIN_NAME=Your Name
ADMIN_EMAIL=your-admin@yourdomain.com
ADMIN_PASSWORD=YourStrongPassword123!

# ── Admin Registration Gate ───────────────────────────────────
# Set to "true" only temporarily to allow POST /api/auth/register
# REMOVE or set to "false" after initial admin is created.
ALLOW_ADMIN_REGISTER=false

# ── Bot Protection (Cloudflare Turnstile) ─────────────────────
# Register at: https://dash.cloudflare.com → Turnstile
# Add your domain and get the site key + secret key.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ── Google OAuth ──────────────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI:
#    - http://localhost:5000/api/users/auth/google/callback  (local)
#    - https://your-app.onrender.com/api/users/auth/google/callback  (prod)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-app.onrender.com/api/users/auth/google/callback

# ── File Uploads ──────────────────────────────────────────────
MAX_FILE_SIZE=5242880  # 5 MB in bytes