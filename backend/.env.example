# ── Google OAuth ──────────────────────────────────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI:
#    - http://localhost:5000/api/users/auth/google/callback  (local)
#    - https://import-export-jhik.onrender.com/api/users/auth/google/callback  (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://import-export-jhik.onrender.com/api/users/auth/google/callback

# ── File Uploads ──────────────────────────────────────────────
MAX_FILE_SIZE=5242880  # 5 MB in bytes